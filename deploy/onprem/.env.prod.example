# On-prem production environment

PROJECT_NAME="ProjectForge AI"
DEPLOYMENT_MODE=onprem
PROJECT_TIER=enterprise

# Security — replace before deploy
ENCRYPTION_KEY=replace-with-a-secure-production-key
RBAC_ENFORCE=true
RBAC_DEFAULT_ACTOR=admin
RBAC_DEFAULT_ROLE=owner

# OAuth — configure real credentials
OAUTH_MOCK_TOKEN_EXCHANGE=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Data stores
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-neo4j-password
POSTGRES_URI=postgresql://projectforge:replace-postgres-password@postgres:5432/projectforge

# Native Locus/OMPA (recommended for on-prem)
REQUIRE_NATIVE_LOCUS_OMPA=true
LOCUS_SOURCE_PATH=/opt/locus
OMPA_SOURCE_PATH=/opt/ompa

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_SYNC_SCHEDULES=true

# URLs
BACKEND_BASE_URL=https://projectforge.internal
FRONTEND_BASE_URL=https://projectforge.internal
NEXT_PUBLIC_API_BASE_URL=https://projectforge.internal
