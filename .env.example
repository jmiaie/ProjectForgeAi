# ProjectForge AI environment variables
# Copy to `.env` and fill in real values for local / staging / prod.

PROJECT_NAME=ProjectForge AI
DEPLOYMENT_MODE=saas
DEFAULT_COMPLIANCE=standard

# LLMs (LiteLLM-compatible model identifiers)
DEFAULT_LLM_MODEL=groq/llama-3.1-70b-versatile
FLAGSHIP_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022

# Optional provider keys (set the ones you actually use)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Persistence
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=projectforge
POSTGRES_URI=postgresql://postgres:postgres@postgres:5432/projectforge
REDIS_URI=redis://redis:6379/0

# Async SQLAlchemy URL. Leave unset to derive from POSTGRES_URI (asyncpg).
# For quick local boot you can use:
#   DATABASE_URL=sqlite+aiosqlite:///./projectforge.db
DATABASE_URL=
DATABASE_ECHO=false
AUTO_CREATE_SCHEMA=false

# Encryption (rotate in production!)
ENCRYPTION_KEY=dev-only-not-secure-change-me

# Storage roots (relative to backend container)
LOCUS_ROOT=./.locus
OMPA_VAULT_ROOT=./vaults
GRAPH_DATA_ROOT=./.graph

# Graph backend: ``memory`` (file-backed JSON, default) or ``neo4j`` (uses
# the async driver against NEO4J_URI / USER / PASSWORD).
GRAPH_BACKEND=memory

# Workflow backend: ``memory`` (in-process polling, default) or ``temporal``
# (uses the temporalio SDK against TEMPORAL_TARGET).
WORKFLOW_BACKEND=memory
TEMPORAL_TARGET=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=projectforge-automations
AUTOMATION_POLL_SECONDS=5

# OAuth provider credentials (leave blank to fall back to the stub connector)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
OAUTH_STATE_TTL_SECONDS=600
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# CORS
ALLOWED_ORIGINS=*
