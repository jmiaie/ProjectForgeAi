PROJECT_NAME="ProjectForge AI"
DEPLOYMENT_MODE=saas
DEFAULT_COMPLIANCE=standard
DEFAULT_LLM_MODEL=groq/llama-3.1-70b-versatile
FLAGSHIP_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
LLM_KEY_ROOT=./.llm-keys
LLM_USAGE_ROOT=./.llm-usage
SPATIAL_ASSET_ROOT=./.spatial
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=projectforge-password
NEO4J_CONNECTION_TIMEOUT=1.0
NEO4J_BOOTSTRAP_ON_CONNECT=true
REQUIRE_NATIVE_NEO4J=false
POSTGRES_URI=postgresql://projectforge:projectforge@postgres:5432/projectforge
ENCRYPTION_KEY=replace-with-a-secure-key
LOCUS_SOURCE_PATH=
LOCUS_ENGINE=locus:LocusEngine
LOCUS_STORE_ROOT=./.locus
OMPA_SOURCE_PATH=
OMPA_ENGINE=ompa:Ompa
OMPA_VAULT_ROOT=./vaults
REQUIRE_NATIVE_LOCUS_OMPA=false
INGESTION_MANIFEST_ROOT=./.ingestion
ORCHESTRATION_RUN_ROOT=./.orchestrator
COMPLIANCE_PROFILE_ROOT=./.compliance
COMPLIANCE_AUDIT_ROOT=./.audit
INTEGRATIONS_CONNECTION_ROOT=./.connections
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_PROJECT_ID=proj_123
AUTOMATION_WORKFLOW_ROOT=./.automations
AUTOMATION_MAX_RETRIES=3
AUTOMATION_RETRY_BACKOFF_SECONDS=60
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=projectforge-automations
TEMPORAL_USE_WORKER_DISPATCH=false
TEMPORAL_SYNC_SCHEDULES=false
OAUTH_MOCK_TOKEN_EXCHANGE=true
OAUTH_ALLOW_UNVERIFIED_STATE=false
GOOGLE_OAUTH_CLIENT_ID=
USE_LANGGRAPH_ORCHESTRATOR=false
USE_LANGGRAPH_BRANCHING=true
RBAC_ENFORCE=false
RBAC_DEFAULT_ACTOR=dev-user
RBAC_DEFAULT_ROLE=owner
RBAC_MEMBERSHIP_ROOT=./.rbac
PROJECT_TIER=starter
PROJECT_REGISTRY_ROOT=./.projects
DEFAULT_PROJECT_ID=proj_123
IMAGE_OCR_ENABLED=true
IMAGE_OCR_TIMEOUT_SECONDS=30
TESSERACT_CMD=
